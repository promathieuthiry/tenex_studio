---
import { SITE_ORIGIN } from '@/lib/i18n';

export type SeoProps = {
  title: string;
  description: string;
  canonical: string;
  ogLocale: string;
  ogImage?: string;
  hreflang: { fr: string; en: string; 'x-default': string };
  jsonLd?: string;
};

const {
  title,
  description,
  canonical,
  ogLocale,
  ogImage,
  hreflang,
  jsonLd,
} = Astro.props as SeoProps;

const canonicalUrl = `${SITE_ORIGIN}${canonical}`;
const ogImageUrl = ogImage ? `${SITE_ORIGIN}${ogImage}` : undefined;
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<link rel="alternate" hreflang="fr" href={`${SITE_ORIGIN}${hreflang.fr}`} />
<link rel="alternate" hreflang="en" href={`${SITE_ORIGIN}${hreflang.en}`} />
<link
  rel="alternate"
  hreflang="x-default"
  href={`${SITE_ORIGIN}${hreflang['x-default']}`}
/>

<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content="Tenex Studio" />
<meta property="og:locale" content={ogLocale} />
{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
{ogImageUrl && <meta property="og:image:width" content="1200" />}
{ogImageUrl && <meta property="og:image:height" content="630" />}

<meta
  name="twitter:card"
  content={ogImageUrl ? 'summary_large_image' : 'summary'}
/>
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

{jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} />}
