---
import { SITE_ORIGIN } from '@/lib/site';
import type { SeoProps } from '@/lib/seo';

const {
  title,
  description,
  canonical,
  ogLocale,
  ogLocaleAlternate,
  ogImage,
  ogImageAlt,
  hreflang,
  robots,
  jsonLd,
  ogType,
  article,
} = Astro.props as SeoProps;

const canonicalUrl = `${SITE_ORIGIN}${canonical}`;
const ogImagePath =
  ogImage ?? (ogLocale.startsWith('fr') ? '/og/og-fr.jpg' : '/og/og-en.jpg');
const ogImageUrl = `${SITE_ORIGIN}${ogImagePath}`;
const imageAlt = ogImageAlt ?? title;
---

<title>{title}</title>
<meta name="description" content={description} />
<meta
  name="robots"
  content={robots ?? "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
/>
<link rel="canonical" href={canonicalUrl} />

<link rel="alternate" hreflang="fr-FR" href={`${SITE_ORIGIN}${hreflang.fr}`} />
<link rel="alternate" hreflang="en-US" href={`${SITE_ORIGIN}${hreflang.en}`} />
<link
  rel="alternate"
  hreflang="x-default"
  href={`${SITE_ORIGIN}${hreflang['x-default']}`}
/>

<meta property="og:type" content={ogType ?? "website"} />
{article && (
  <>
    <meta property="article:published_time" content={article.publishedTime} />
    <meta property="article:modified_time" content={article.modifiedTime} />
    <meta property="article:author" content={article.author} />
    {article.section && (
      <meta property="article:section" content={article.section} />
    )}
  </>
)}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content="TeneX Studio" />
<meta property="og:locale" content={ogLocale} />
{ogLocaleAlternate && (
  <meta property="og:locale:alternate" content={ogLocaleAlternate} />
)}
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:alt" content={imageAlt} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={imageAlt} />

{jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} />}
