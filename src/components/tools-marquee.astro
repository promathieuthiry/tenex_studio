---
import type { Locale } from '@/lib/i18n';
import { TOOLS, TOOLS_EYEBROW } from '@/data/tools';

const { locale } = Astro.props as { locale: Locale };

// Duplicate the set so a -50% translate loops seamlessly (same trick as the
// vertical marquee in mono-hero.tsx).
const loop = [...TOOLS, ...TOOLS];
---

<section aria-label={TOOLS_EYEBROW[locale]} class="bg-paper py-20 md:py-28">
  <p class="px-6 text-center font-mono text-xs uppercase tracking-[0.12em] text-ink/55 md:px-10">
    {TOOLS_EYEBROW[locale]}
  </p>
  <div
    class="mt-10 overflow-hidden [mask-image:linear-gradient(to_right,transparent,#000_12%,#000_88%,transparent)] [-webkit-mask-image:linear-gradient(to_right,transparent,#000_12%,#000_88%,transparent)]"
  >
    <ul
      class="flex w-max items-center gap-12 [&:hover]:[animation-play-state:paused] md:gap-16"
      style="animation: marquee-x 60s linear infinite"
    >
      {
        loop.map((tool, i) => (
          <li class="shrink-0">
            <img
              src={`/logos/${tool.file}.svg`}
              alt={i >= TOOLS.length ? '' : tool.name}
              aria-hidden={i >= TOOLS.length}
              width={120}
              height={36}
              loading="lazy"
              decoding="async"
              class="h-7 w-auto opacity-50 grayscale transition duration-300 hover:opacity-100 hover:grayscale-0 md:h-9"
            />
          </li>
        ))
      }
    </ul>
  </div>
</section>
