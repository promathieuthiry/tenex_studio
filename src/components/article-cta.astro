---
import type { Locale } from "@/lib/i18n";
import { BOOK_URL, BOOK_LINK_ATTRS } from "@/lib/book";

const { locale } = Astro.props as { locale: Locale };

const t = {
  heading: {
    fr: "Un site qui convertit, en ligne en deux semaines.",
    en: "A site that converts, live in two weeks.",
  },
  body: {
    fr: "Trente minutes pour cadrer votre projet. Réponse sous 24 heures ouvrées.",
    en: "Thirty minutes to scope your project. We reply within one business day.",
  },
  cta: { fr: "Réserver un appel", en: "Book a call" },
} as const;
---

<div class="relative bg-paper-cool/50 p-6 md:p-7">
  <span class="block h-px w-8 bg-accent" aria-hidden="true"></span>
  <p class="mt-5 font-display text-xl leading-[1.15] tracking-[-0.02em] text-ink">
    {t.heading[locale]}
  </p>
  <p class="mt-4 font-sans text-[13px] leading-6 text-ink/60">
    {t.body[locale]}
  </p>
  <a
    href={BOOK_URL}
    {...BOOK_LINK_ATTRS}
    class="group mt-6 inline-flex h-11 w-full items-center justify-center gap-2 rounded-full bg-ink px-5 font-sans text-sm text-paper transition hover:opacity-80"
  >
    {t.cta[locale]}
    <svg
      aria-hidden="true"
      viewBox="0 0 15 15"
      fill="none"
      class="h-4 w-4 shrink-0 transition-transform duration-300 ease-out group-hover:translate-x-1"
    >
      <path
        d="M8.146 3.146a.5.5 0 0 1 .708 0l3.5 3.5a.5.5 0 0 1 0 .708l-3.5 3.5a.5.5 0 0 1-.708-.708L10.793 7.5H3a.5.5 0 0 1 0-1h7.793L8.146 3.854a.5.5 0 0 1 0-.708Z"
        fill="currentColor"></path>
    </svg>
  </a>
</div>
