---
const { src, alt, title, ...props } = Astro.props as {
  src: string;
  alt?: string;
  title?: string;
};
---
<figure class="mt-10 first:mt-0">
  <img
    {...props}
    src={src}
    alt={alt ?? ""}
    loading="lazy"
    decoding="async"
    class="w-full rounded-sm border border-ink/8 bg-paper-deep"
  />
  {
    title && (
      <figcaption class="mt-3 font-mono text-[11px] uppercase tracking-[0.14em] text-ink/45">
        {title}
      </figcaption>
    )
  }
</figure>
