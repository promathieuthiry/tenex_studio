---
import { render } from "astro:content";
import type { Locale } from "@/lib/i18n";
import { pathFor } from "@/lib/i18n";
import type { BlogEntry } from "@/lib/blog";
import { relatedPosts, postSlug } from "@/lib/blog";
import { proseComponents } from "@/components/article-prose";
import { BlogCard } from "@/components/blog-card";
import { Faq } from "@/components/faq";
import ArticleCta from "@/components/article-cta.astro";

const { entry, locale } = Astro.props as { entry: BlogEntry; locale: Locale };

const { Content } = await render(entry);

const dateLabel = new Intl.DateTimeFormat(locale, {
  year: "numeric",
  month: "short",
  day: "numeric",
}).format(entry.data.date);

const related = await relatedPosts(entry);

const t = {
  back: { fr: "Tous les articles", en: "All articles" },
  author: { fr: "Auteur", en: "Author" },
  related: { fr: "À lire ensuite", en: "Read next" },
  faq: { fr: "Questions fréquentes", en: "Frequently asked questions" },
} as const;

const faqHeader = {
  title: t.faq,
} as const;

const faqItems = entry.data.faq.map((item, index) => ({
  number: String(index + 1).padStart(2, "0"),
  question: { fr: item.question, en: item.question },
  answer: { fr: item.answer, en: item.answer },
}));
---

<article id="main">
  <header class="px-6 pt-32 md:px-10 md:pt-40">
    <div class="mx-auto max-w-7xl">
      <a
        href={pathFor(locale, "/blog")}
        class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60 transition-opacity duration-300 hover:opacity-60"
        >← {t.back[locale]}</a
      >

      <figure
        class="relative mt-8 flex min-h-[30rem] flex-col justify-end overflow-hidden bg-paper-deep px-6 py-8 md:mt-10 md:min-h-[38rem] md:px-10 md:py-12"
      >
        <img
          src={entry.data.cover}
          alt=""
          loading="eager"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <span
          class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/55 to-ink/10"
          aria-hidden="true"></span>
        <figcaption class="relative max-w-4xl">
          <h1
            class="font-display text-3xl leading-[1.05] tracking-[-0.02em] text-paper md:text-6xl"
          >
            {entry.data.title}
          </h1>

          <p class="mt-5 max-w-2xl font-sans text-base leading-7 text-paper/85 md:text-lg md:leading-8">
            {entry.data.excerpt}
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-3">
            <div class="flex items-center gap-3">
              <img
                src="/portrait/mathieu-thiry-linkedin.webp"
                alt={entry.data.author}
                width="40"
                height="40"
                loading="eager"
                decoding="async"
                class="size-10 shrink-0 rounded-full object-cover ring-1 ring-paper/25"
              />
              <span>
                <span class="block font-display text-base leading-tight tracking-[-0.01em] text-paper"
                  >{entry.data.author}</span
                >
                <span class="block font-mono text-[11px] uppercase tracking-[0.14em] text-paper/60"
                  >{entry.data.authorRole}</span
                >
              </span>
            </div>

            <span class="hidden h-8 w-px bg-paper/20 sm:block" aria-hidden="true"></span>

            <div class="flex flex-wrap items-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-paper/70">
              <time datetime={entry.data.date.toISOString()}>{dateLabel}</time>
              <span class="text-paper/35" aria-hidden="true">/</span>
              <span>{entry.data.category.join(" · ")}</span>
            </div>
          </div>
        </figcaption>
      </figure>
    </div>
  </header>

  <div class="px-6 py-16 md:px-10 md:py-24">
    <div
      class="mx-auto max-w-7xl lg:grid lg:grid-cols-[minmax(0,42rem)_16rem] lg:justify-center lg:gap-16 xl:gap-24"
    >
      <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-none">
        <Content components={proseComponents} />

        <div class="mt-16 border-t border-ink/8 pt-10 lg:hidden">
          <ArticleCta locale={locale} />
        </div>
      </div>

      <aside class="hidden lg:block">
        <div class="sticky top-32">
          <ArticleCta locale={locale} />
        </div>
      </aside>
    </div>
  </div>

  <Faq client:visible locale={locale} items={faqItems} header={faqHeader} />

  {
    related.length > 0 && (
      <section
        class="border-t border-ink/8 px-6 py-24 md:px-10 md:py-32"
        aria-labelledby="related-heading"
      >
        <div class="mx-auto max-w-7xl">
          <div class="flex flex-wrap items-end justify-between gap-6">
            <h2
              id="related-heading"
              class="font-display text-3xl leading-[1.05] tracking-[-0.03em] text-ink md:text-5xl"
            >
              {t.related[locale]}
            </h2>
            <a
              href={pathFor(locale, "/blog")}
              class="shrink-0 rounded-full border border-ink/15 px-4 py-2 font-sans text-xs text-ink transition-colors duration-300 hover:border-ink/35"
            >
              {t.back[locale]}
            </a>
          </div>
          <ul class="mt-16 grid gap-6 md:grid-cols-3 md:gap-8">
            {related.map((item) => (
              <li>
                <BlogCard
                  href={pathFor(locale, `/blog/${postSlug(item)}`)}
                  title={item.data.title}
                  category={item.data.category}
                  cover={item.data.cover}
                  date={item.data.date.toISOString()}
                  locale={locale}
                />
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</article>
