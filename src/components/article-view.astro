---
import { render } from "astro:content";
import type { Locale } from "@/lib/i18n";
import { pathFor } from "@/lib/i18n";
import type { BlogEntry } from "@/lib/blog";
import { relatedPosts, postSlug } from "@/lib/blog";
import { proseComponents } from "@/components/article-prose";
import { BlogCard } from "@/components/blog-card";

const { entry, locale } = Astro.props as { entry: BlogEntry; locale: Locale };

const { Content } = await render(entry);

const dateLabel = new Intl.DateTimeFormat(locale, {
  year: "numeric",
  month: "short",
  day: "numeric",
}).format(entry.data.date);

const initials = entry.data.author
  .split(" ")
  .map((part) => part[0])
  .slice(0, 2)
  .join("");

const related = await relatedPosts(entry);

const t = {
  back: { fr: "Tous les articles", en: "All articles" },
  author: { fr: "Auteur", en: "Author" },
  related: { fr: "À lire ensuite", en: "Read next" },
} as const;
---

<article id="main">
  <header class="px-6 pt-32 md:px-10 md:pt-40">
    <div class="mx-auto max-w-7xl">
      <a
        href={pathFor(locale, "/blog")}
        class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60 transition-opacity duration-300 hover:opacity-60"
        >← {t.back[locale]}</a
      >
      <figure
        class="relative mt-8 aspect-16/10 overflow-hidden bg-paper-deep md:aspect-21/9"
      >
        <img
          src={entry.data.cover}
          alt=""
          loading="eager"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <span
          class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/35 to-transparent"
          aria-hidden="true"></span>
        <figcaption
          class="absolute inset-x-6 bottom-6 max-w-4xl font-display text-3xl leading-[1.05] tracking-[-0.02em] text-paper md:inset-x-10 md:bottom-10 md:text-6xl"
        >
          {entry.data.title}
        </figcaption>
      </figure>
    </div>
  </header>

  <div class="px-6 py-16 md:px-10 md:py-24">
    <div
      class="mx-auto grid max-w-7xl gap-12 md:grid-cols-[18rem_1fr] md:gap-16"
    >
      <aside class="md:sticky md:top-28 md:self-start">
        <div class="flex flex-wrap items-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60">
          <time datetime={entry.data.date.toISOString()}>{dateLabel}</time>
          <span class="text-ink/25" aria-hidden="true">/</span>
          <span>{entry.data.category}</span>
        </div>

        <p class="mt-8 font-mono text-[11px] uppercase tracking-[0.18em] text-ink/40">
          {t.author[locale]}
        </p>
        <div class="mt-3 flex items-center gap-3">
          <span
            class="grid size-10 shrink-0 place-items-center rounded-full bg-ink font-mono text-xs text-paper"
            aria-hidden="true">{initials}</span
          >
          <span>
            <span class="block font-display text-lg leading-tight tracking-[-0.01em] text-ink"
              >{entry.data.author}</span
            >
            <span class="block font-mono text-[11px] uppercase tracking-[0.14em] text-ink/55"
              >{entry.data.authorRole}</span
            >
          </span>
        </div>

        <p class="mt-8 max-w-prose font-sans text-[15px] leading-7 text-ink/70">
          {entry.data.excerpt}
        </p>
      </aside>

      <div class="max-w-2xl">
        <Content components={proseComponents} />
      </div>
    </div>
  </div>

  {
    related.length > 0 && (
      <section
        class="border-t border-ink/8 px-6 py-24 md:px-10 md:py-32"
        aria-labelledby="related-heading"
      >
        <div class="mx-auto max-w-7xl">
          <div class="flex flex-wrap items-end justify-between gap-6">
            <h2
              id="related-heading"
              class="font-display text-3xl leading-[1.05] tracking-[-0.03em] text-ink md:text-5xl"
            >
              {t.related[locale]}
            </h2>
            <a
              href={pathFor(locale, "/blog")}
              class="shrink-0 rounded-full border border-ink/15 px-4 py-2 font-sans text-xs text-ink transition-colors duration-300 hover:border-ink/35"
            >
              {t.back[locale]}
            </a>
          </div>
          <ul class="mt-16 grid gap-6 md:grid-cols-3 md:gap-8">
            {related.map((item) => (
              <li>
                <BlogCard
                  href={pathFor(locale, `/blog/${postSlug(item)}`)}
                  title={item.data.title}
                  category={item.data.category}
                  cover={item.data.cover}
                  date={item.data.date.toISOString()}
                  locale={locale}
                />
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</article>
