---
import { render } from "astro:content";
import type { Locale } from "@/lib/i18n";
import { pathFor } from "@/lib/i18n";
import type { BlogEntry } from "@/lib/blog";
import { relatedPosts, postSlug } from "@/lib/blog";
import { proseComponents } from "@/components/article-prose";
import { BlogCard } from "@/components/blog-card";
import { Faq } from "@/components/faq";
import ArticleCta from "@/components/article-cta.astro";
import { BODY_SM, META, TITLE_LG } from "@/lib/type";

const { entry, locale } = Astro.props as { entry: BlogEntry; locale: Locale };

const { Content } = await render(entry);

const dateLabel = new Intl.DateTimeFormat(locale, {
  year: "numeric",
  month: "short",
  day: "numeric",
}).format(entry.data.date);

const related = await relatedPosts(entry);

const t = {
  back: { fr: "Tous les articles", en: "All articles" },
  author: { fr: "Auteur", en: "Author" },
  related: { fr: "À lire ensuite", en: "Read next" },
  faq: { fr: "Questions fréquentes", en: "Frequently asked questions" },
} as const;

const faqHeader = {
  title: t.faq,
} as const;

const faqItems = entry.data.faq.map((item, index) => ({
  id: `faq-${index}`,
  question: { fr: item.question, en: item.question },
  answer: { fr: item.answer, en: item.answer },
}));
---

<article id="main">
  <header class="px-6 pt-32 md:px-10 md:pt-40">
    <div
      class="mx-auto max-w-7xl lg:grid lg:grid-cols-[minmax(0,42rem)_16rem] lg:justify-center lg:gap-16 xl:gap-24"
    >
      <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-none">
        <a
          href={pathFor(locale, "/blog")}
          class={`${META} text-ink/60 transition-opacity duration-300 hover:opacity-60`}
          >← {t.back[locale]}</a
        >

        <figure class="mt-6 overflow-hidden rounded-sm bg-paper-deep md:mt-8">
          <img
            src={entry.data.cover}
            alt=""
            loading="eager"
            decoding="async"
            class="block aspect-2/1 w-full object-cover"
          />

          <figcaption class="bg-ink p-6 md:p-8">
            <h1 class={`${TITLE_LG} text-paper`}>
              {entry.data.title}
            </h1>

            <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2">
              <img
                src="/portrait/mathieu-thiry-linkedin.webp"
                alt={entry.data.author}
                width="32"
                height="32"
                loading="eager"
                decoding="async"
                class="size-8 shrink-0 rounded-full object-cover ring-1 ring-paper/25"
              />
              <span class={`${BODY_SM} font-medium text-paper`}>{entry.data.author}</span>
              <span class="text-paper/35" aria-hidden="true">/</span>
              <time class={`${META} text-paper/70`} datetime={entry.data.date.toISOString()}
                >{dateLabel}</time
              >

              {
                entry.data.category.map((label) => (
                  <span
                    class={`rounded-full border border-paper/20 px-3 py-1 ${META} text-paper/70`}
                  >
                    {label}
                  </span>
                ))
              }
            </div>
          </figcaption>
        </figure>
      </div>
    </div>
  </header>

  <div class="px-6 py-16 md:px-10 md:py-24">
    <div
      class="mx-auto max-w-7xl lg:grid lg:grid-cols-[minmax(0,42rem)_16rem] lg:justify-center lg:gap-16 xl:gap-24"
    >
      <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-none">
        <Content components={proseComponents} />

        <div class="mt-16 border-t border-ink/8 pt-10 lg:hidden">
          <ArticleCta locale={locale} />
        </div>
      </div>

      <aside class="hidden lg:block">
        <div class="sticky top-32">
          <ArticleCta locale={locale} />
        </div>
      </aside>
    </div>
  </div>

  <Faq client:visible locale={locale} items={faqItems} header={faqHeader} />

  {
    related.length > 0 && (
      <section
        class="border-t border-ink/8 px-6 py-24 md:px-10 md:py-32"
        aria-labelledby="related-heading"
      >
        <div class="mx-auto max-w-7xl">
          <div class="flex flex-wrap items-end justify-between gap-6">
            <h2 id="related-heading" class={`${TITLE_LG} text-ink`}>
              {t.related[locale]}
            </h2>
            <a
              href={pathFor(locale, "/blog")}
              class={`shrink-0 rounded-full border border-ink/15 px-4 py-2 ${BODY_SM} text-ink transition-colors duration-300 hover:border-ink/35`}
            >
              {t.back[locale]}
            </a>
          </div>
          <ul class="mt-16 grid gap-6 md:grid-cols-3 md:gap-8">
            {related.map((item) => (
              <li>
                <BlogCard
                  href={pathFor(locale, `/blog/${postSlug(item)}`)}
                  title={item.data.title}
                  category={item.data.category}
                  cover={item.data.cover}
                  date={item.data.date.toISOString()}
                  locale={locale}
                />
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</article>
