---
import type { Locale } from '@/lib/i18n';
import { MonoHero } from '@/components/mono-hero';
import { Services } from '@/components/services';
import { WorkShowcase } from '@/components/work-showcase';
import { MonogramReveal } from '@/components/monogram-reveal';
import ToolsMarquee from '@/components/tools-marquee.astro';
import { Testimonials } from '@/components/testimonials';
import { Pricing } from '@/components/pricing';
import { Faq } from '@/components/faq';
import { ContactCta } from '@/components/contact-cta';

const { locale } = Astro.props as { locale: Locale };
---

<MonoHero client:load locale={locale} />
<Services client:visible locale={locale} />
<WorkShowcase client:visible locale={locale} />
<MonogramReveal client:visible locale={locale} />
<!-- <ToolsMarquee locale={locale} /> -->
<Testimonials client:visible locale={locale} />
<Pricing client:visible locale={locale} />
<Faq client:visible locale={locale} />
<ContactCta client:visible locale={locale} />
