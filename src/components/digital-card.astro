---
import type { Locale } from "@/lib/i18n";
import { BOOK_LINK_ATTRS, BOOK_URL } from "@/lib/book";
import {
  DIGITAL_CARD,
  DIGITAL_CARD_EMAIL,
  DIGITAL_CARD_PHOTO,
  DIGITAL_CARD_PHONE,
  DIGITAL_CARD_PHONE_HREF,
  DIGITAL_CARD_VCF,
  DIGITAL_CARD_WEBSITE,
} from "@/data/digital-card";

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const content = DIGITAL_CARD[locale];
const websiteLabel = new URL(DIGITAL_CARD_WEBSITE).hostname;
const [firstName = content.name, ...lastNameParts] = content.name.split(" ");
const lastName = lastNameParts.join(" ");
---

<section class="min-h-[calc(100svh-var(--nav-h))] bg-paper pt-[calc(var(--nav-h)+28px)] md:pt-[calc(var(--nav-h)+34px)]">
  <div class="mx-auto grid max-w-7xl gap-9 px-6 pb-20 md:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] md:items-start md:px-10 md:pb-24">
    <div class="relative mx-auto w-full max-w-[340px] md:mx-0 lg:max-w-[360px]">
      <div class="aspect-[4/5] overflow-hidden bg-paper-warm">
        <img
          src={DIGITAL_CARD_PHOTO}
          alt={content.photoAlt}
          width="900"
          height="1125"
          class="h-full w-full object-cover object-[50%_12%] grayscale"
        />
      </div>
      <div class="pointer-events-none absolute inset-0 border border-ink/8"></div>
    </div>

    <div class="max-w-3xl">
      <p class="font-mono text-[11px] font-medium uppercase tracking-[0.18em] text-ink/45">
        {content.eyebrow}
      </p>

      <h1 class="mt-4 font-display text-[clamp(3.75rem,9.5vw,7rem)] font-bold leading-[0.85] tracking-[-0.06em] text-ink">
        {firstName}<br />{lastName}
      </h1>

      <div class="mt-6 h-1 w-full max-w-xl bg-accent"></div>

      <div class="mt-6 grid gap-6 sm:grid-cols-2">
        <div>
          <p class="font-mono text-[11px] font-medium uppercase tracking-[0.16em] text-ink/40">
            {content.role}
          </p>
          <p class="mt-2 font-sans text-lg font-semibold leading-[1.1] text-ink">
            {content.studio}
          </p>
          <div class="mt-4">
            <p class="font-mono text-[11px] font-medium uppercase tracking-[0.16em] text-ink/40">
              {content.websiteLabel}
            </p>
            <p class="mt-2 font-sans text-base font-medium leading-[1.1] text-ink">
              <a href={DIGITAL_CARD_WEBSITE} class="hover:opacity-70">
                {websiteLabel}
              </a>
            </p>
          </div>
        </div>

        <dl class="grid gap-4">
          <div>
            <dt class="font-mono text-[11px] font-medium uppercase tracking-[0.16em] text-ink/40">
              {content.emailLabel}
            </dt>
            <dd class="mt-2 font-sans text-base font-medium leading-[1.1] text-ink">
              <a href={`mailto:${DIGITAL_CARD_EMAIL}`} class="hover:opacity-70">
                {DIGITAL_CARD_EMAIL}
              </a>
            </dd>
          </div>
          <div>
            <dt class="font-mono text-[11px] font-medium uppercase tracking-[0.16em] text-ink/40">
              {content.phoneLabel}
            </dt>
            <dd class="mt-2 font-sans text-base font-medium leading-[1.1] text-ink">
              <a href={DIGITAL_CARD_PHONE_HREF} class="hover:opacity-70">
                {DIGITAL_CARD_PHONE}
              </a>
            </dd>
          </div>
        </dl>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={BOOK_URL}
          target={BOOK_LINK_ATTRS.target}
          rel={BOOK_LINK_ATTRS.rel}
          class="inline-flex items-center justify-center rounded-full bg-ink px-6 py-3 font-sans text-sm font-medium text-paper transition hover:opacity-80"
        >
          {content.bookCta}
        </a>
        <a
          href={DIGITAL_CARD_VCF[locale]}
          download
          class="inline-flex items-center justify-center rounded-full border border-ink/20 px-6 py-3 font-sans text-sm font-medium text-ink transition hover:border-ink"
        >
          {content.contactCta}
        </a>
      </div>
    </div>
  </div>
</section>
