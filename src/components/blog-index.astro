---
import type { Locale } from '@/lib/i18n';
import { pathFor } from '@/lib/i18n';
import { postsForLocale, postSlug, BLOG_INDEX } from '@/lib/blog';
import { BlogCard } from '@/components/blog-card';

const { locale } = Astro.props as { locale: Locale };

const posts = await postsForLocale(locale);
---

<section
  id="main"
  class="px-6 pb-24 pt-32 md:px-10 md:pb-40 md:pt-48"
  aria-labelledby="blog-index-heading"
>
  <div class="mx-auto max-w-7xl">
    <header class="max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.12em] text-ink/60">
        {BLOG_INDEX.eyebrow[locale]}
      </p>
      <h1
        id="blog-index-heading"
        class="mt-6 font-display text-5xl leading-[1] tracking-[-0.03em] text-ink md:text-8xl"
      >
        {BLOG_INDEX.title[locale]}
      </h1>
    </header>

    <ul class="mt-16 grid gap-6 md:mt-20 md:grid-cols-3 md:gap-8">
      {
        posts.map((post, i) => (
          <li>
            <BlogCard
              href={pathFor(locale, `/blog/${postSlug(post)}`)}
              title={post.data.title}
              category={post.data.category}
              cover={post.data.cover}
              date={post.data.date.toISOString()}
              locale={locale}
              priority={i < 3}
            />
          </li>
        ))
      }
    </ul>
  </div>
</section>
