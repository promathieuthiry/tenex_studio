---
import type { Locale } from '@/lib/i18n';
import { pathFor } from '@/lib/i18n';
import { postsForLocale, postSlug, BLOG_INDEX } from '@/lib/blog';
import { BlogCard } from '@/components/blog-card';
import { SECTION_LEAD, CONTAINER, HEADER_GAP } from '@/lib/layout';
import { TITLE_PAGE } from "@/lib/type";

const { locale } = Astro.props as { locale: Locale };

const posts = await postsForLocale(locale);
---

<section id="main" class={SECTION_LEAD} aria-labelledby="blog-index-heading">
  <div class={CONTAINER}>
    <header class="max-w-3xl">
      <h1
        id="blog-index-heading"
        class={`${TITLE_PAGE} text-ink`}
      >
        {BLOG_INDEX.title[locale]}
      </h1>
    </header>

    <ul class={`${HEADER_GAP} grid gap-6 md:grid-cols-3 md:gap-8`}>
      {
        posts.map((post, i) => (
          <li>
            <BlogCard
              href={pathFor(locale, `/blog/${postSlug(post)}`)}
              title={post.data.title}
              category={post.data.category}
              cover={post.data.cover}
              date={post.data.date.toISOString()}
              locale={locale}
              priority={i < 3}
            />
          </li>
        ))
      }
    </ul>
  </div>
</section>
