---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomeView from '@/components/HomeView.astro';
import { buildHomeSeo } from '@/lib/seo';

const locale = 'fr' as const;
const seo = buildHomeSeo(locale);
---

<BaseLayout locale={locale} seo={seo}>
  <HomeView locale={locale} />
</BaseLayout>
