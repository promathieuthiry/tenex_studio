---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ResourcesIndex from '@/components/resources-index.astro';
import { buildResourcesSeo } from '@/lib/seo';

const locale = 'en' as const;
const seo = buildResourcesSeo(locale);
---

<BaseLayout locale={locale} seo={seo}>
  <ResourcesIndex locale={locale} />
</BaseLayout>
